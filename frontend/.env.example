# Copy to .env (or .env.local) for local dev. Vite exposes VITE_* to the client.

# FastAPI gateway base URL. In production point at your API subdomain.
VITE_API_BASE=http://localhost:8000

# PocketBase base URL — used by the admin panel to log in and get a token.
VITE_POCKETBASE_URL=http://localhost:8090

# PocketBase collection that admin logins authenticate against.
# Must match the backend's POCKETBASE_ADMIN_COLLECTION (default: _superusers).
VITE_POCKETBASE_COLLECTION=_superusers
