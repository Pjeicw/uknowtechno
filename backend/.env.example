# =====================================================================
#  UknowTechno — Backend environment blueprint  (COPY to .env, never commit .env)
#  Real secrets live in Coolify's secret store in production, not in git.
# =====================================================================

# --- PocketBase (auth / config / budgets) ---------------------------
POCKETBASE_URL=http://pocketbase_container:8090
POCKETBASE_ADMIN_USER=admin@uknowtechno.com
POCKETBASE_ADMIN_PASSWORD=your_secure_password_here
# Which PocketBase collection admin tokens are verified against.
# Use "_superusers" for PocketBase superusers, or a custom "users" collection.
POCKETBASE_ADMIN_COLLECTION=_superusers
# Staff users (role-gated chat knowledge, G3). Add a text field named below to
# your PocketBase "users" collection with values: public|staff|technical_staff|admin.
POCKETBASE_USER_COLLECTION=users
POCKETBASE_ROLE_FIELD=role
# LOCAL DEV ONLY: a shared secret that unlocks the admin panel without PocketBase.
# Set any value here and enter it under "LOCAL DEV ACCESS" on the /admin login.
# Leave EMPTY in production so only PocketBase logins work.
ADMIN_DEV_TOKEN=

# --- Local Processing Node (Ollama) ---------------------------------
# Code reads OLLAMA_API_URL first, then falls back to OLLAMA_HOST.
OLLAMA_API_URL=http://your_asus_workstation_ip:11434
VECTOR_DB_URL=http://qdrant_container:6333

# --- Cloudflare AI Gateway (BYOK) -----------------------------------
# Cloud LLM calls route THROUGH the gateway. Raw provider keys are NOT stored
# here or anywhere on this host — they live in Cloudflare Secrets Store and are
# referenced by name below. The only cloud secret on this host is CF_AIG_TOKEN.
CF_ACCOUNT_ID=your_cloudflare_account_id
CF_AIG_GATEWAY=your_gateway_id
CF_AIG_TOKEN=your_gateway_auth_token          # rotatable, spend-limited
DEEPSEEK_KEY_REF=DEEPSEEK_KEY_1               # Secrets Store reference name
OPENAI_KEY_REF=OPENAI_KEY_1                   # Secrets Store reference name

# --- Security policy (Phase 1) --------------------------------------
# Comma-separated list of origins allowed to call the API from a browser.
# Do NOT use "*" together with credentials — browsers reject it and it's insecure.
CORS_ALLOWED_ORIGINS=https://uknowtechno.com,http://localhost:5173
# Rate limit for the public /api/chat endpoint (slowapi syntax).
CHAT_RATE_LIMIT=20/minute

# --- Disaster Recovery Storage (Cloudflare R2) ----------------------
CLOUDFLARE_ACCOUNT_ID=your_cloudflare_account_id
CLOUDFLARE_R2_BUCKET=uknowtechno-backups
CLOUDFLARE_R2_ACCESS_KEY=your_r2_access_key
CLOUDFLARE_R2_SECRET_KEY=your_r2_secret_key
